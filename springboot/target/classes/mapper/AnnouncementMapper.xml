<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.studyroom.mapper.AnnouncementMapper">
    <resultMap id="BaseResultMap" type="com.studyroom.entity.Announcement">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="type" property="type"/>
        <result column="priority" property="priority"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, title, content, type, priority, status, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM announcement
        WHERE id = #{id}
    </select>

    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM announcement
        WHERE status = #{status}
        ORDER BY priority DESC, create_time DESC
    </select>

    <select id="selectByType" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM announcement
        WHERE type = #{type}
        ORDER BY create_time DESC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM announcement
        ORDER BY create_time DESC
    </select>

    <insert id="insert" parameterType="com.studyroom.entity.Announcement" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO announcement (title, content, type, priority, status, create_time, update_time)
        VALUES (#{title}, #{content}, #{type}, #{priority}, #{status}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.studyroom.entity.Announcement">
        UPDATE announcement
        SET title = #{title},
            content = #{content},
            type = #{type},
            priority = #{priority},
            status = #{status},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM announcement WHERE id = #{id}
    </delete>
</mapper>
